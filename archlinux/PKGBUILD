pkgname=picpro
pkgver=0.4.1
pkgdesc="picpro a kitsrus PIC CLI programmer"
pkgrel=1
arch=('any')
license=('GPL-2.0')
url='https://github.com/Salamek/picpro'
makedepends=(python-build python-installer python-wheel python-setuptools)
depends=(
    'python'
    'python-docopt'
    'python-pyserial'
    'python-intelhex'
    'python-yaml'
    'python-platformdirs'
)

prepare() {
  mkdir -p "${srcdir}/${pkgname}"
  cp -R "${srcdir}/../../picpro" "${srcdir}/${pkgname}"
  cp -R "${srcdir}/../../tests" "${srcdir}/${pkgname}"
  cp -R "${srcdir}/../../pyproject.toml" "${srcdir}/${pkgname}"
  cp -R "${srcdir}/../../README.md" "${srcdir}/${pkgname}"
}

build() {
    cd "${srcdir}/${pkgname}"
    python -m build --wheel --no-isolation
}

package() {
    cd "${srcdir}/${pkgname}"
    python -m installer --destdir="$pkgdir" dist/*.whl
}
